# Database - REQUIRED: Use these exact variable names

# Prisma Accelerate URL — used by the app at RUNTIME (connection pooling via Prisma Accelerate)
# Format: prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_API_KEY_HERE
jacxi_PRISMA_DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_API_KEY_HERE"

# Direct PostgreSQL connection — used by Prisma Migrate (CLI only, bypasses Accelerate)
# Format: postgres://user:password@db.prisma.io:5432/postgres?sslmode=require
jacxi_POSTGRES_URL="postgres://user:password@db.prisma.io:5432/postgres?sslmode=require"

# Direct PostgreSQL connection — legacy / backward compatibility with scripts
jacxi_DATABASE_URL="postgres://user:password@db.prisma.io:5432/postgres?sslmode=require"
DATABASE_URL="postgres://user:password@db.prisma.io:5432/postgres?sslmode=require"

# Authentication
# IMPORTANT: NEXTAUTH_SECRET must be a secure random string (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-secret-here"
# NEXTAUTH_URL must match your deployment URL for cookies to work properly
# For local development: http://localhost:3000
# For production: https://yourdomain.com
NEXTAUTH_URL="http://localhost:3000"

# Email Service (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxxx"

# Application URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cron Job Security (for automatic tracking updates)
CRON_SECRET="your-cron-secret-here"

# Optional: Webhook Security (if using webhooks)
TRACKING_WEBHOOK_SECRET="your-webhook-secret-here"
