{
  "name": "jacxi-shipping",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate --no-engine && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate --no-engine",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:migrate:resolve": "node scripts/resolve-failed-migration.js",
    "db:seed": "node scripts/init-db.js",
    "db:studio": "prisma studio",
    "db:backup": "node scripts/backup-db.js",
    "db:backfill-notification-senders": "node scripts/backfill-notification-senders.js",
    "db:reset": "node scripts/reset-db.js",
    "db:setup": "npm run db:generate && npm run db:push && npm run db:seed",
    "db:full-reset": "npm run db:reset && npm run db:seed",
    "test": "node --experimental-strip-types --test 'src/**/*.test.ts'",
    "test:routes": "tsx --test src/app/api/workflow-routes.test.ts",
    "test:e2e": "playwright test",
    "postinstall": "prisma generate --no-engine"
  },
