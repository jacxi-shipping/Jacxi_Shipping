    "@types/bcryptjs": "^2.4.6",
    "@types/leaflet": "^1.9.21",
    "@vercel/blob": "^2.0.0",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "driver.js": "^1.4.0",
    "framer-motion": "^12.23.24",
    "i18next": "^25.6.0",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
